# local/env.sh.example
# shellcheck shell=bash
#
# Unified Configuration Vault -- Namespaced Source of Truth
# All variables are prefixed with DOTFILES_ to avoid system collisions.

# -- system ------------------------------------------------------------------
# export DOTFILES_PROJECT_NAME="batdots"
# export DOTFILES_PROJECT_DESCRIPTION="dotfiles management framework"
# export DOTFILES_LOG_LEVEL="INFO" # DEBUG, INFO, WARN, ERROR, FATAL

# -- git ---------------------------------------------------------------------
# Format: "alias:email:Full Name"
# export DOTFILES_GIT_AUTHORS=(
#   "personal:your-handle@users.noreply.github.com:Your Name"
#   "work:you@company.com:Your Real Name"
# )

# -- backups -----------------------------------------------------------------
# export DOTFILES_BACKUP_SOURCES=( "$HOME/Documents" "$HOME/Pictures" )
# export DOTFILES_BACKUP_DIR="/media/user/USB/Backup"

# restic repos, in order -- every reachable one receives each snapshot (3-2-1).
# Put an air-gapped local/USB repo first; remotes (rclone:/sftp:/rest:/b2:) after.
# export DOTFILES_RESTIC_REPOS=(
#   "/media/user/USB/restic"
#   "rclone:gdrive:backups/laptop"
# )
# export DOTFILES_RESTIC_PASS_FILE="${DOTFILES_ROOT}/local/restic_pass"
# export DOTFILES_RESTIC_BACKUP_PATHS=( "$HOME/Documents" "$HOME/Pictures" )
# Pre-wire ad-hoc `restic ...` on the command line (the scripts set these per-repo
# themselves; this is just the default target for manual use):
# export RESTIC_PASSWORD_FILE="$DOTFILES_RESTIC_PASS_FILE"
# export RESTIC_REPOSITORY="rclone:gdrive:backups/laptop"
# Retention (optional; these are the defaults):
# export DOTFILES_RESTIC_KEEP_DAILY=7 DOTFILES_RESTIC_KEEP_WEEKLY=4
# export DOTFILES_RESTIC_KEEP_MONTHLY=12 DOTFILES_RESTIC_KEEP_YEARLY=3
# Verification (optional; weekly restic-check re-reads this fraction of pack data,
# monthly restic-test-restore pulls this sentinel file back to prove restores work):
# export DOTFILES_RESTIC_CHECK_SUBSET="1/7"
# export DOTFILES_RESTIC_TESTRESTORE_PATH="${DOTFILES_ROOT}/local/env.sh"

# -- battery -----------------------------------------------------------------
# export DOTFILES_BATTERY_LOW_THRESHOLD=15

# -- cloud sync --------------------------------------------------------------
# export DOTFILES_RCLONE_SYNC_SRC="$HOME/Pictures"
# export DOTFILES_RCLONE_SYNC_DEST="gdrive:Pictures"

# -- PARA file organization (para-doctor) ------------------------------------
# export DOTFILES_PARA_ROOT="$HOME/Documents"          # required to run para-doctor
# export DOTFILES_PARA_INBOX_STALE_DAYS=30             # inbox item is "stale" past this age
# export DOTFILES_PARA_LARGE_FILE_MB=100               # flag files at/above this size

# -- media directories -------------------------------------------------------
# export DOTFILES_AUDIO_DIR="$HOME/Documents/3_RESOURCES/AUDIOS"
# export DOTFILES_PDF_DIR="$HOME/Documents/3_RESOURCES/PDFS"
# export DOTFILES_SCREENSHOT_DIR="$HOME/Documents/3_RESOURCES/SCREENSHOTS"
# export DOTFILES_WALLPAPER_DIR="$HOME/Documents/3_RESOURCES/WALLPAPERS"  # default: $HOME/Pictures/wallpapers
# export DOTFILES_VIDEO_DIR="$HOME/Videos"
# export DOTFILES_OBS_REC_DIR="$HOME/Videos"
# export DOTFILES_YT_MP3_DIR="$HOME/Documents/3_RESOURCES/AUDIOS/Youtube"
# export DOTFILES_YT_MP4_DIR="$HOME/Videos/Youtube"
# export DOTFILES_SVG_LOGOS_DIR="$HOME/Documents/3_RESOURCES/IMAGES/LOGOS/svg"
# export DOTFILES_SCREENCAST_DIR="$HOME/Videos/Screencasts"
# export DOTFILES_NOTES_ASSETS_DIR="$HOME/Documents/3_RESOURCES/NOTES/00_ASSETS"

# -- markdown front matter ---------------------------------------------------
# Default author used by scripts/user/add-yaml-front-matter.sh.
# export DOTFILES_AUTHOR="Your Name"

# -- notifications -----------------------------------------------------------
# export DOTFILES_PUSHOVER_API_KEY=""
# export DOTFILES_PUSHOVER_USER_KEY=""
# export DOTFILES_DISCORD_WEBHOOK=""

# -- security cameras (hikvision/rtsp) ---------------------------------------
# export DOTFILES_DVR_IP="192.168.1.100"
# export DOTFILES_DVR_USER="admin"
# export DOTFILES_DVR_PASS="your-password"   # reserved chars (@ : /) are URL-encoded for you
# export DOTFILES_DVR_PORT=554
# export DOTFILES_DVR_STREAM=1               # 1 = main stream, 2 = sub stream
# export DOTFILES_DVR_CHANNELS=(1 2)
# Default path is Hikvision-style; override for other brands (e.g. Dahua:
# "cam/realmonitor?channel=__CH__&subtype=0"). __STREAM__ is zero-padded.
# export DOTFILES_DVR_URL_TEMPLATE="Streaming/Channels/__CH____STREAM__"

# -- prayer times ------------------------------------------------------------
export DOTFILES_PRAYER_CITY="Rabat"
export DOTFILES_PRAYER_COUNTRY="Morocco"
export DOTFILES_PRAYER_METHOD=3
export DOTFILES_PRAYER_BACKEND="aladhan"
export DOTFILES_PRAYER_SCRAPE_URL="https://www.habous.gov.ma/prieres/horaire-api.php?ville={ID}"

# -- gotenberg (self-hosted document -> PDF) ----------------------------------
# Base URL of your Gotenberg instance, used by scripts/user/office-to-pdf.sh.
# Default is Gotenberg's own default; override to your self-hosted endpoint.
export DOTFILES_GOTENBERG_URL=http://gotenberg.homelab.lan:80

# --- APPS ---
export DOTFILES_LXTERMINAL_CONFIG="${HOME}/.config/lxterminal/lxterminal.conf"
export DOTFILES_LXTERMINAL_THEMES_DIR="${HOME}/.config/lxterminal/themes"


# -- pdf sanitize (scripts/user/pdf-sanitize.sh) -----------------------------
export DOTFILES_YARA_RULES="${HOME}/.local/share/dotfiles/yara/pdf-rules.yarc"
export DOTFILES_YARA_MAX_AGE_HOURS=24
export DOTFILES_YARA_AUTO_REFRESH=1
export DOTFILES_YARA_GIT_TIMEOUT=120
export DOTFILES_PDF_SANITIZE_PARANOID=0
export DOTFILES_PDF_SANITIZE_OCR=0
export DOTFILES_PDF_SANITIZE_DPI=200
export DOTFILES_PDF_SANITIZE_REPORT=0

# -- development -------------------------------------------------------------
# export DOTFILES_VSCODE_PROJECT_ID=""

# -- brightness --------------------------------------------------------------
export DOTFILES_BRIGHTNESS_STEP=5
export DOTFILES_ICON_DIR_BRIGHTNESS="${HOME}/.local/share/icons/dotfiles"

# -- video -------------------------------------------------------------------
export DOTFILES_VIDEO_TRIM_CRF=20
export DOTFILES_VIDEO_CONCAT_FPS=30
export DOTFILES_VIDEO_ARCHIVE_CRF=22
export DOTFILES_VIDEO_ARCHIVE_PRESET="medium"
export DOTFILES_VIDEO_SANITIZE_CRF=23
export DOTFILES_VIDEO_SANITIZE_PRESET="medium"

# -- nemo file manager -------------------------------------------------------
# Target where Nemo reads action files (XDG-defined; only override if you've
# moved XDG_DATA_HOME or use a non-standard layout).
# export DOTFILES_NEMO_ACTIONS_DIR="${XDG_DATA_HOME:-$HOME/.local/share}/nemo/actions"
#
# Source directory in this repo for personal .nemo_action files.
# export DOTFILES_NEMO_PERSONAL_ACTIONS_DIR="${DOTFILES_ROOT}/apps/nemo/actions"

# -- machine-specific PATH additions -----------------------------------------
# export DOTFILES_EXTRA_PATHS=(
#   "$HOME/go/bin"
#   "$HOME/.cargo/bin"
# )
