root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

[*.md]
# Don't strip trailing spaces -- Markdown uses them for hard line breaks.
trim_trailing_whitespace = false

[Makefile]
indent_style = tab

[*.{conf,txt}]
# Whitespace in config tables is intentional (alignment).
trim_trailing_whitespace = false
