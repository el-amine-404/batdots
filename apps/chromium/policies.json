{
  "PolicyRefreshRate": 1200,
  "_comment_privacy": "=== PRIVACY & TELEMETRY ===",
  "MetricsReportingEnabled": false,
  "ComponentUpdatesEnabled": false,
  "ChromeCleanupEnabled": false,
  "ChromeCleanupReportingEnabled": false,
  "NetworkPredictionOptions": 2,
  "UrlKeyedAnonymizedDataCollectionEnabled": false,
  "UserFeedbackAllowed": false,
  "PromotionalTabsEnabled": false,
  "SearchSuggestEnabled": false,
  "AutofillAddressEnabled": false,
  "AutofillCreditCardEnabled": false,
  "PasswordManagerEnabled": false,
  "BrowserSignin": 0,
  "SyncDisabled": true,
  "BackgroundModeEnabled": false,
  "_comment_amnesia": "=== AMNESIA (CLEAR ON EXIT) ===",
  "SavingBrowserHistoryDisabled": true,
  "ClearBrowsingDataOnExitList": [
    "browsing_history",
    "download_history",
    "cookies_and_other_site_data",
    "cached_images_and_files",
    "password_signin",
    "autofill",
    "site_settings",
    "hosted_app_data"
  ],
  "_comment_security": "=== SECURITY HARDENING ===",
  "SafeBrowsingProtectionLevel": 1,
  "SafeBrowsingProxiedAllowlistDomains": [],
  "BlockThirdPartyCookies": true,
  "CookiesAllowedForUrls": [],
  "CookiesBlockedForUrls": [],
  "DefaultCookiesSetting": 1,
  "JavaScriptEnabled": true,
  "InsecureContentAllowedForUrls": [],
  "LegacySameSiteCookieBehaviorEnabledForDomainList": [],
  "AdsSettingForIntrusiveAdsSites": 2,
  "DownloadRestrictions": 0,
  "ScreenCaptureAllowed": false,
  "AudioCaptureAllowed": false,
  "VideoCaptureAllowed": false,
  "DefaultSearchProviderEnabled": true,
  "DefaultSearchProviderName": "Google",
  "DefaultSearchProviderKeyword": "google",
  "DefaultSearchProviderSearchURL": "https://www.google.com/search?q={searchTerms}",
  "DefaultSearchProviderSuggestURL": "{google:baseURL}complete/search?output=chrome&q={searchTerms}",
  "SiteSearchSettings": [
    {
      "name": "YouTube",
      "shortcut": "_yt",
      "url": "https://www.youtube.com/results?search_query={searchTerms}"
    },
    {
      "name": "GitHub Repositories",
      "shortcut": "_gh",
      "url": "https://github.com/search?q={searchTerms}&type=repositories"
    },
    {
      "name": "Stack Overflow",
      "shortcut": "_so",
      "url": "https://stackoverflow.com/search?q={searchTerms}"
    },
    {
      "name": "Spring Framework Docs",
      "shortcut": "_spring",
      "url": "https://www.google.com/search?q=site:docs.spring.io+{searchTerms}&hl=en"
    },
    {
      "name": "Linux Man Pages",
      "shortcut": "_man",
      "url": "https://www.die.net/search/?q={searchTerms}"
    }
  ],
  "ExtensionInstallBlocklist": ["*"],
  "ExtensionInstallForcelist": [
    "nngceckbapebfimnlniiiahkandclblb;https://clients2.google.com/service/update2/crx",
    "ddkjiahejlhfcafbddmgiahcphecmpfh;https://clients2.google.com/service/update2/crx"
  ],
  "IncognitoModeAvailability": 0,
  "_comment_network": "=== NETWORK SECURITY ===",
  "DNSOverHttpsMode": "secure",
  "DNSOverHttpsTemplates": "https://dns.quad9.net/dns-query",
  "WPADQuickCheckEnabled": false,
  "EnableMediaRouter": false,
  "WebRtcUdpPortRange": "10000-12000",
  "WebRtcIPHandlingPolicy": "disable_non_proxied_udp",
  "_comment_ai": "=== DISABLE ALL AI FEATURES ===",
  "GenAiDefaultSettings": 2,
  "DevToolsGenAiSettings": 2,
  "GeminiSettings": 2,
  "GenAIPhotoEditingSettings": 2,
  "GenAISmartGroupingSettings": 2,
  "GenAiChromeOsSmartActionsSettings": 2,
  "AutofillPredictionSettings": 2,
  "OptimizationGuideModelDownloadingEnabled": false,
  "_comment_ui": "=== UI DE-CLUTTER ===",
  "ShowHomeButton": true,
  "HomepageLocation": "about:blank",
  "RestoreOnStartup": 1,
  "HideWebStoreIcon": true,
  "ShoppingListEnabled": false,
  "SideSearchEnabled": false,
  "LensOverlaySettings": 1,
  "GoogleLensShortcutEnabled": false,
  "_comment_brave_specifics": "These will be ignored by Chrome/Chromium",
  "BraveRewardsDisabled": true,
  "BraveWalletDisabled": true,
  "TorDisabled": true,
  "BraveAIChatEnabled": false
}
